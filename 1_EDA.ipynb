# No mostrar advertencias
import warnings
warnings.filterwarnings('ignore')

import numpy as np
import pandas as pd

import matplotlib.pyplot as plt
import seaborn as sns


# Cargar datos

df = pd.read_csv('./data/retailmax.csv')


df.head()

. ¿Cuál es la distribución de edades de los clientes?

Histograma de Age

plt.figure(figsize=(10,5))

sns.histplot(
    df["Age"],
    bins=15,
    kde=True
)

plt.title("Distribución de edades de los clientes")
plt.xlabel("Edad")
plt.ylabel("Cantidad de clientes")

plt.show()

2. ¿Existen diferencias significativas en los ingresos anuales entre hombres y mujeres?

Boxplot de Annual Income por género

plt.figure(figsize=(8,5))

sns.boxplot(
    data=df,
    x="Gender",
    y="Annual Income (k$)"
)

plt.title("Comparación de ingresos anuales entre géneros")
plt.xlabel("Género")
plt.ylabel("Ingreso anual (k$)")

plt.show()

3. ¿Cómo se distribuye la puntuación de gasto entre diferentes rangos de edad?

Scatter plot Edad vs Spending Score

plt.figure(figsize=(10,5))

sns.scatterplot(
    data=df,
    x="Age",
    y="Spending Score (1-100)"
)

plt.title("Relación entre edad y puntuación de gasto")
plt.xlabel("Edad")
plt.ylabel("Spending Score (1-100)")

plt.show()

4. ¿Cuál es la correlación entre ingreso anual y puntuación de gasto?

Dispersión + coeficiente de correlación

plt.figure(figsize=(10,5))

sns.scatterplot(
    data=df,
    x="Annual Income (k$)",
    y="Spending Score (1-100)"
)

plt.title("Ingreso anual frente a puntuación de gasto")
plt.xlabel("Ingreso anual (k$)")
plt.ylabel("Spending Score (1-100)")

plt.show()


correlacion = df[
    "Annual Income (k$)"
].corr(
    df["Spending Score (1-100)"]
)


print(
    "Coeficiente de correlación:",
    round(correlacion,3)
)
5. ¿Cómo varía la puntuación de gasto en diferentes grupos de ingresos anuales?

Creamos rangos de ingreso:

df["Income_Group"] = pd.cut(
    df["Annual Income (k$)"],
    bins=4,
    labels=[
        "Ingreso bajo",
        "Ingreso medio",
        "Ingreso alto",
        "Ingreso muy alto"
    ]
)


plt.figure(figsize=(10,5))

sns.boxplot(
    data=df,
    x="Income_Group",
    y="Spending Score (1-100)"
)


plt.title(
    "Distribución del gasto según grupos de ingreso"
)

plt.xlabel(
    "Grupo de ingreso"
)

plt.ylabel(
    "Spending Score"
)


plt.show()
6. ¿Cuál es la proporción de clientes por género?

Gráfica de pastel

generos = df["Gender"].value_counts()


plt.figure(figsize=(7,7))

plt.pie(
    generos.values,
    labels=generos.index,
    autopct="%1.1f%%"
)


plt.title(
    "Proporción de clientes por género"
)


plt.show()
7. ¿Qué grupos de edad gastan más en promedio?

Creamos grupos de edad:

df["Age_Group"] = pd.cut(
    df["Age"],
    bins=[
        18,
        30,
        40,
        50,
        60,
        80
    ],
    labels=[
        "18-30",
        "31-40",
        "41-50",
        "51-60",
        "60+"
    ]
)


gasto_promedio = df.groupby(
    "Age_Group"
)["Spending Score (1-100)"].mean()



plt.figure(figsize=(10,5))


sns.barplot(
    x=gasto_promedio.index,
    y=gasto_promedio.values
)


plt.title(
    "Gasto promedio según grupo de edad"
)

plt.xlabel(
    "Grupo de edad"
)

plt.ylabel(
    "Spending Score promedio"
)


plt.show()
8. ¿Hay alguna relación entre edad e ingreso anual?

Scatter plot

plt.figure(figsize=(10,5))


sns.scatterplot(
    data=df,
    x="Age",
    y="Annual Income (k$)"
)


plt.title(
    "Relación entre edad e ingreso anual"
)

plt.xlabel(
    "Edad"
)

plt.ylabel(
    "Ingreso anual (k$)"
)


plt.show()
9. ¿Cuál es la distribución conjunta de edad e ingreso anual?

Gráfico hexagonal

plt.figure(figsize=(10,6))


plt.hexbin(
    df["Age"],
    df["Annual Income (k$)"],
    gridsize=20
)


plt.colorbar(
    label="Cantidad de clientes"
)


plt.title(
    "Distribución conjunta de edad e ingreso anual"
)


plt.xlabel(
    "Edad"
)

plt.ylabel(
    "Ingreso anual (k$)"
)


plt.show()
10. ¿Cómo se distribuyen los clientes según gasto y género?

Violín por género

plt.figure(figsize=(10,5))


sns.violinplot(
    data=df,
